# ---- Frontend (Vite, safe to expose) ----
# Anything prefixed VITE_ is compiled into the JS bundle and is PUBLIC.
# Never put a service-role key, an OpenAI key or any other secret behind VITE_.
# These two are required — the app refuses to start in a production build without
# them, because the no-Supabase fallback is an unauthenticated demo mode.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Escape hatch for an intentionally public, seed-data-only demo build. Demo mode
# auto-signs-in as an admin with NO password — never set this on a deployment
# that points at real data.
# VITE_ALLOW_DEMO=true

# ---- Edge Functions / server-only (NEVER expose to browser) ----
# Set these with: supabase secrets set KEY=value
OPENAI_API_KEY=sk-...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated allowlist of app origins. Used for CORS and as the ONLY
# permitted OAuth redirect targets — an unvalidated redirect_to was an open
# redirect. No trailing slashes; must match window.location.origin exactly.
APP_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Google OAuth (Gmail + Calendar)
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...

# Slack
SLACK_CLIENT_ID=...
SLACK_CLIENT_SECRET=...
SLACK_SIGNING_SECRET=...
SLACK_BOT_TOKEN=xoxb-...
